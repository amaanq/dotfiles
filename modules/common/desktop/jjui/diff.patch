+func (m *Model) cycleDiffEditor() tea.Cmd {
+	tool := config.Current.CycleDiffEditor()
+	cmds := []tea.Cmd{
+		func() tea.Msg {
+			return intents.AddMessage{Text: fmt.Sprintf("Diff tool: %s", tool)}
+		},
+	}
+	if m.diff != nil && m.lastDiffRevision != "" {
+		revision := m.lastDiffRevision
