+		cmds = append(cmds, func() tea.Msg {
+			diffTool := config.GetCurrentDiffTool(config.Current)
+			var args jj.CommandArgs
+			if diffTool != "" {
+				args = jj.Diff(revision, fileName, "--config=ui.diff-formatter="+diffTool)
+			} else {
+				args = jj.Diff(revision, fileName)
+			}
+			output, _ := m.context.RunCommandImmediate(args)
+			return intents.DiffShow{Content: string(output), Revision: revision, FileName: fileName}
+		})
+	}
